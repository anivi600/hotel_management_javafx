<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.RowConstraints?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="tab-content-root"
      fx:controller="com.hotel.controllers.RoomController" spacing="0.0">
   <children>
      <VBox spacing="10.0" styleClass="form-panel">
         <children>
            <Label styleClass="form-title" text="Add New Room" />
            <GridPane hgap="12.0" vgap="10.0">
               <columnConstraints>
                  <ColumnConstraints prefWidth="130.0" />
                  <ColumnConstraints prefWidth="200.0" />
                  <ColumnConstraints prefWidth="130.0" />
                  <ColumnConstraints prefWidth="200.0" />
               </columnConstraints>
               <children>
                  <Label styleClass="section-label" text="Room Number:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <TextField fx:id="tfRoomNumber" promptText="e.g. 101" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Label styleClass="section-label" text="Room Type:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <ComboBox fx:id="cbRoomType" prefWidth="200.0" promptText="Select Type" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                  <Label styleClass="section-label" text="Price / Night (₹):" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="tfBasePrice" promptText="e.g. 2000" GridPane.columnIndex="1" GridPane.rowIndex="1" />
               </children>
               <padding>
                  <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
               </padding>
            </GridPane>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="btnAdd" mnemonicParsing="false" text="➕  Add Room" />
                  <Button fx:id="btnDelete" mnemonicParsing="false" styleClass="button-danger" text="🗑  Delete Room" />
                  <Button fx:id="btnFilter" mnemonicParsing="false" text="🔍  Show Available" />
                  <Button fx:id="btnAll" mnemonicParsing="false" text="📋  Show All Rooms" />
                  <Button fx:id="btnSortP" mnemonicParsing="false" text="↕  Sort by Price" />
               </children>
               <padding>
                  <Insets bottom="0.0" left="0.0" right="0.0" top="4.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding>
      </VBox>
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </TableView>
   </children>
</VBox>
