<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.ColumnConstraints?>
<?import javafx.scene.layout.GridPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="tab-content-root"
      fx:controller="com.hotel.controllers.BookingController" spacing="0.0">
   <children>
      <VBox spacing="10.0" styleClass="form-panel">
         <children>
            <Label styleClass="form-title" text="Create New Booking" />
            <GridPane hgap="12.0" vgap="10.0">
               <columnConstraints>
                  <ColumnConstraints prefWidth="140.0" />
                  <ColumnConstraints prefWidth="220.0" />
                  <ColumnConstraints prefWidth="140.0" />
                  <ColumnConstraints prefWidth="220.0" />
               </columnConstraints>
               <children>
                  <Label styleClass="section-label" text="Customer:" GridPane.columnIndex="0" GridPane.rowIndex="0" />
                  <ComboBox fx:id="cbCustomer" prefWidth="220.0" promptText="Select customer" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                  <Label styleClass="section-label" text="Available Room:" GridPane.columnIndex="2" GridPane.rowIndex="0" />
                  <ComboBox fx:id="cbRoom" prefWidth="220.0" promptText="Select available room" GridPane.columnIndex="3" GridPane.rowIndex="0" />
                  <Label styleClass="section-label" text="Number of Nights:" GridPane.columnIndex="0" GridPane.rowIndex="1" />
                  <TextField fx:id="tfNights" promptText="e.g. 3" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                  <Label styleClass="section-label" text="Discount % (0–1):" GridPane.columnIndex="2" GridPane.rowIndex="1" />
                  <TextField fx:id="tfDiscount" promptText="e.g. 0.05" text="0.05" GridPane.columnIndex="3" GridPane.rowIndex="1" />
               </children>
               <padding>
                  <Insets bottom="8.0" left="0.0" right="0.0" top="8.0" />
               </padding>
            </GridPane>
            <HBox alignment="CENTER_LEFT" spacing="10.0">
               <children>
                  <Button fx:id="btnBook" mnemonicParsing="false" text="📅  Book Room" />
                  <Button fx:id="btnCheckout" mnemonicParsing="false" styleClass="button-success" text="🏁  Checkout" />
               </children>
               <padding>
                  <Insets bottom="0.0" left="0.0" right="0.0" top="4.0" />
               </padding>
            </HBox>
         </children>
         <padding>
            <Insets bottom="16.0" left="16.0" right="16.0" top="16.0" />
         </padding>
      </VBox>
      <TableView fx:id="tableView" VBox.vgrow="ALWAYS">
         <padding>
            <Insets bottom="8.0" left="8.0" right="8.0" top="8.0" />
         </padding>
      </TableView>
   </children>
</VBox>
