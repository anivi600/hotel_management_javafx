<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="bill-dialog-root"
      fx:controller="com.hotel.controllers.BillDialogController"
      alignment="TOP_CENTER" spacing="0.0"
      stylesheets="@styles.css">
   <children>
      <TextArea fx:id="receiptArea" editable="false" styleClass="bill-receipt-text" wrapText="true" VBox.vgrow="ALWAYS" />
      <HBox alignment="CENTER" spacing="12.0">
         <children>
            <Button fx:id="btnSave" mnemonicParsing="false" text="💾  Save Bill" />
            <Button fx:id="btnClose" mnemonicParsing="false" styleClass="button-danger" text="✖  Close" />
         </children>
         <padding>
            <Insets bottom="20.0" left="20.0" right="20.0" top="16.0" />
         </padding>
      </HBox>
   </children>
   <padding>
      <Insets bottom="20.0" left="20.0" right="20.0" top="20.0" />
   </padding>
</VBox>
