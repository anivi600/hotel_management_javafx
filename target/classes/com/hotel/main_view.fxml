<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.Tab?>
<?import javafx.scene.control.TabPane?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Priority?>
<?import javafx.scene.layout.VBox?>

<VBox xmlns="http://javafx.com/javafx/21" xmlns:fx="http://javafx.com/fxml/1"
      styleClass="app-root"
      fx:controller="com.hotel.controllers.MainController"
      stylesheets="@styles.css">
   <children>
      <HBox fx:id="headerBox" alignment="CENTER_LEFT" spacing="18.0" styleClass="header-bar">
         <children>
            <Label fx:id="titleLabel" styleClass="hotel-title" text="🏨  Four Square Hotel Manipal">
               <HBox.hgrow>
                  <Priority fx:constant="ALWAYS" />
               </HBox.hgrow>
            </Label>
            <Button fx:id="btnExport" mnemonicParsing="false" styleClass="export-btn" text="📊  Export Data" />
            <Button fx:id="btnLogout" mnemonicParsing="false" styleClass="export-btn" style="-fx-background-color: #d64545; -fx-text-fill: white;" text="🚪 Logout" />
            <Label fx:id="dateLabel" styleClass="header-date" text="📅" />
         </children>
         <padding>
            <Insets bottom="2.0" left="0.0" right="0.0" top="0.0" />
         </padding>
      </HBox>
      <TabPane fx:id="tabPane" styleClass="main-tabs" tabClosingPolicy="UNAVAILABLE" VBox.vgrow="ALWAYS">
         <tabs>
            <Tab fx:id="tabRoom" closable="false" text="🛏  Room Management">
               <content>
                  <fx:include fx:id="roomTab" source="room_tab.fxml" />
               </content>
            </Tab>
            <Tab fx:id="tabCustomer" closable="false" text="👤  Customer Management">
               <content>
                  <fx:include fx:id="customerTab" source="customer_tab.fxml" />
               </content>
            </Tab>
            <Tab fx:id="tabBooking" closable="false" text="📅  Bookings">
               <content>
                  <fx:include fx:id="bookingTab" source="booking_tab.fxml" />
               </content>
            </Tab>
            <Tab fx:id="tabBilling" closable="false" text="🧾  Billing History">
               <content>
                  <fx:include fx:id="billingTab" source="billing_tab.fxml" />
               </content>
            </Tab>
            <Tab fx:id="tabHousekeeping" closable="false" text="🧹  Housekeeping">
               <content>
                  <fx:include fx:id="housekeepingTab" source="housekeeping_tab.fxml" />
               </content>
            </Tab>
         </tabs>
      </TabPane>
      <HBox alignment="CENTER_LEFT" styleClass="status-bar">
         <children>
            <Label fx:id="statusLabel" styleClass="status-label" text="  Ready." />
         </children>
         <padding>
            <Insets bottom="5.0" left="10.0" right="10.0" top="5.0" />
         </padding>
      </HBox>
   </children>
</VBox>
